PORT=5000
MONGODB_URI=mongodb://localhost:27017/lifetwin
JWT_SECRET=your-super-secret-jwt-key-here
FRONTEND_URL=http://localhost:3000
NODE_ENV=development

# ─── LLM API Keys ────────────────────────────────────────────────────────────
# OpenAI (GPT-4, GPT-3.5-Turbo, OpenAI Embeddings) – format: sk-...
OPENAI_API_KEY=
# Anthropic (Claude 3 Opus, Claude 3 Sonnet) – format: sk-ant-api03-...
ANTHROPIC_API_KEY=
# Hugging Face (Llama 2, Mistral 7B, HF Embeddings) – format: hf_...
HUGGINGFACE_API_KEY=
# Google Generative AI (Gemini Pro) – format: AIza...
GOOGLE_GENAI_API_KEY=
# Cohere (Cohere Embeddings) – format: ...
COHERE_API_KEY=

# ─── Default Model Selection ─────────────────────────────────────────────────
# LLM options: gpt-4 | gpt-3.5-turbo | claude-3-opus | claude-3-sonnet | llama-2 | mistral-7b | gemini-pro
DEFAULT_LLM_MODEL=gpt-3.5-turbo
# RAG framework options: langchain | llamaindex
DEFAULT_RAG_FRAMEWORK=langchain
# Embedding options: openai-embeddings | huggingface-embeddings | cohere-embeddings
DEFAULT_EMBEDDING_MODEL=openai-embeddings
